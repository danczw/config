[user]
  name = danczw
  email = github.cdx7q@dcx.cx

[core]
  editor = hx
  autocrlf = input
  pager = less -F -X
  safecrlf = true
  excludesfile = ~/.gitignore_global

[init]
  defaultBranch = main

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[fetch]
  prune = true

[rebase]
  autoStash = true

[merge]
  conflictStyle = zdiff3

[rerere]
  enabled = true
