// Reference layout using zjstatus (https://github.com/dj95/zjstatus).
// Not installed by install.sh; copy to ~/.config/zellij/layouts/ to activate.
// Themed for ayu-mirage; uses ASCII indicators only (no Nerd Fonts required).
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/latest/download/zjstatus.wasm" {
                format_left   "{mode}#[bg=#1f2430] {tabs}"
                format_center "#[bg=#1f2430,fg=#686868] Zellij: #[bg=#1f2430,fg=#686868]{session}"
                format_right  "{swap_layout}"
                format_space  "#[bg=#1f2430]"
                format_hide_on_overlength "true"
                format_precedence "crl"

                border_enabled  "false"
                border_char     "─"
                border_format   "#[fg=#686868]{char}"
                border_position "top"

                hide_frame_for_single_pane "true"

                mode_normal        "#[bg=#a6cc70,fg=#191e2a,bold] NORMAL#[bg=#1f2430,fg=#a6cc70]"
                mode_locked        "#[bg=#686868,fg=#191e2a,bold] LOCKED #[bg=#1f2430,fg=#686868]"
                mode_resize        "#[bg=#6dcbfa,fg=#191e2a,bold] RESIZE#[bg=#1f2430,fg=#6dcbfa]"
                mode_pane          "#[bg=#6dcbfa,fg=#191e2a,bold] PANE#[bg=#1f2430,fg=#6dcbfa]"
                mode_tab           "#[bg=#6dcbfa,fg=#191e2a,bold] TAB#[bg=#1f2430,fg=#6dcbfa]"
                mode_scroll        "#[bg=#6dcbfa,fg=#191e2a,bold] SCROLL#[bg=#1f2430,fg=#6dcbfa]"
                mode_enter_search  "#[bg=#6dcbfa,fg=#191e2a,bold] ENT-SEARCH#[bg=#1f2430,fg=#6dcbfa]"
                mode_search        "#[bg=#6dcbfa,fg=#191e2a,bold] SEARCH#[bg=#1f2430,fg=#6dcbfa]"
                mode_rename_tab    "#[bg=#6dcbfa,fg=#191e2a,bold] RENAME-TAB#[bg=#1f2430,fg=#6dcbfa]"
                mode_rename_pane   "#[bg=#6dcbfa,fg=#191e2a,bold] RENAME-PANE#[bg=#1f2430,fg=#6dcbfa]"
                mode_session       "#[bg=#6dcbfa,fg=#191e2a,bold] SESSION#[bg=#1f2430,fg=#6dcbfa]"
                mode_move          "#[bg=#6dcbfa,fg=#191e2a,bold] MOVE#[bg=#1f2430,fg=#6dcbfa]"
                mode_prompt        "#[bg=#6dcbfa,fg=#191e2a,bold] PROMPT#[bg=#1f2430,fg=#6dcbfa]"
                mode_tmux          "#[bg=#f28779,fg=#191e2a,bold] TMUX#[bg=#1f2430,fg=#f28779]"

                // formatting for inactive tabs
                tab_normal              "#[bg=#1f2430,fg=#90e1c6]#[bg=#90e1c6,fg=#191e2a,bold]{index} #[bg=#2b303a,fg=#90e1c6,bold] {name}{floating_indicator}#[bg=#1f2430,fg=#2b303a,bold]"
                tab_normal_fullscreen   "#[bg=#1f2430,fg=#90e1c6]#[bg=#90e1c6,fg=#191e2a,bold]{index} #[bg=#2b303a,fg=#90e1c6,bold] {name}{fullscreen_indicator}#[bg=#1f2430,fg=#2b303a,bold]"
                tab_normal_sync         "#[bg=#1f2430,fg=#90e1c6]#[bg=#90e1c6,fg=#191e2a,bold]{index} #[bg=#2b303a,fg=#90e1c6,bold] {name}{sync_indicator}#[bg=#1f2430,fg=#2b303a,bold]"

                // formatting for the current active tab
                tab_active              "#[bg=#1f2430,fg=#fad07b]#[bg=#fad07b,fg=#191e2a,bold]{index} #[bg=#2b303a,fg=#fad07b,bold] {name}{floating_indicator}#[bg=#1f2430,fg=#2b303a,bold]"
                tab_active_fullscreen   "#[bg=#1f2430,fg=#fad07b]#[bg=#fad07b,fg=#191e2a,bold]{index} #[bg=#2b303a,fg=#fad07b,bold] {name}{fullscreen_indicator}#[bg=#1f2430,fg=#2b303a,bold]"
                tab_active_sync         "#[bg=#1f2430,fg=#fad07b]#[bg=#fad07b,fg=#191e2a,bold]{index} #[bg=#2b303a,fg=#fad07b,bold] {name}{sync_indicator}#[bg=#1f2430,fg=#2b303a,bold]"

                // separator between the tabs
                tab_separator           "#[bg=#1f2430] "

                // indicators (ASCII only)
                tab_sync_indicator       " ="
                tab_fullscreen_indicator " *"
                tab_floating_indicator   " ~"

                command_git_branch_command     "git rev-parse --abbrev-ref HEAD"
                command_git_branch_format      "#[fg=#6dcbfa] {stdout} "
                command_git_branch_interval    "10"
                command_git_branch_rendermode  "static"

                datetime        "#[fg=#686868,bold] {format} "
                datetime_format "%A, %d %b %Y %H:%M"
                datetime_timezone "Europe/Berlin"
            }
        }
        children
    }
	tab {
		pane
	}
}
